# App URL (used for email confirmation & password reset links; set in production)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase - AMC project (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://ooheotsnplfrpgblrnot.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Dashboard > Authentication > URL Configuration:
# - Site URL: your AMS app URL (e.g. http://localhost:3000 or https://your-domain.com)
# - Redirect URLs: add callback URLs for your app origin, e.g.
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback
#   Or use a wildcard: https://your-domain.com/** (covers ?intent=register on register)

# Google OAuth (Supabase Auth > Providers > Google, and Google Cloud Console)
# Authorized redirect URI in Google: https://ooheotsnplfrpgblrnot.supabase.co/auth/v1/callback
# Must match NEXT_PUBLIC_SUPABASE_URL (AMS project ref: ooheotsnplfrpgblrnot).
# Add http://localhost:3000/auth/callback (or http://localhost:3000/**) to Supabase Auth > URL Configuration > Redirect URLs
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Service role key (server-only � must match the project above)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database URL (for migrations - get from Supabase Dashboard > Settings > Database > Connection string > URI)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or set SUPABASE_DB_PASSWORD instead (region defaults to eu-central-1; override with SUPABASE_DB_REGION)

# Payment webhook secret (for Paystack, Flutterwave, etc.)
# PAYMENT_WEBHOOK_SECRET=

# WhatsApp via Twilio (for mass outreach and fee reminders)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Cron job secret (protects /api/cron/fee-reminders)
# CRON_SECRET=your_random_secret_here

# School ID (used in campaign pages � set to your school's UUID)
# NEXT_PUBLIC_SCHOOL_ID=your_school_uuid_here

# Optional: Sentry (for error monitoring)
# SENTRY_DSN=your_sentry_dsn
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# SENTRY_ORG=your_org_slug
# SENTRY_PROJECT=your_project_slug
