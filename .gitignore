scripts/.migration-export.json
scripts/.migration.sql
scripts/.migration-*.sql
scripts/.migration-inserts.json
scripts/.mig-stmt-*.sql
scripts/.mig-stmt-*-query.json

# Supabase
supabase/.temp

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
